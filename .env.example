# ============================================================
# TASO – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Telegram ────────────────────────────────────────────────
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated list of admin Telegram user IDs (numeric)
# Find your ID by sending /start – it will be logged and shown.
TELEGRAM_ADMIN_IDS=

# Comma-separated Telegram usernames (without @) – alternative to IDs
TELEGRAM_ADMIN_USERNAMES=your_username_here

# ── LLM Backend ─────────────────────────────────────────────
# Supported: ollama | openai | anthropic | copilot
LLM_BACKEND=ollama

# GitHub Copilot / GitHub Models (OpenAI-compatible endpoint)
# IMPORTANT: Requires a CLASSIC PAT (starts with ghp_), NOT a fine-grained PAT.
# Generate at: https://github.com/settings/tokens (classic)
# No special scope needed — GitHub Models access is tied to your account.
# Your account must have GitHub Copilot or GitHub Models beta access.
GITHUB_TOKEN=
COPILOT_API_BASE=https://models.github.ai/inference
COPILOT_MODEL=openai/gpt-4o

# Fallback backend used when primary backend returns auth errors
LLM_FALLBACK_BACKEND=ollama

# Ollama (local, recommended for privacy)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (cloud)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (cloud)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Database ────────────────────────────────────────────────
DB_PATH=data/taso.db
VECTOR_INDEX_PATH=data/faiss.index
VECTOR_META_PATH=data/faiss_meta.pkl

# ── Docker Sandbox ──────────────────────────────────────────
DOCKER_SANDBOX_IMAGE=python:3.11-slim
DOCKER_MEM_LIMIT=256m
DOCKER_CPU_QUOTA=50000
DOCKER_TIMEOUT=60
# true = bridge network (outbound internet); false = fully isolated
DOCKER_NETWORK_ENABLED=false

# ── Tor / SOCKS Proxy ───────────────────────────────────────
TOR_ENABLED=false
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050

# ── Self-Improvement ────────────────────────────────────────
SELF_IMPROVE_ENABLED=false
MAX_PATCH_LINES=500
# Modules that are NEVER auto-patched (comma-separated directory names)
PROTECTED_MODULES=config,sandbox,self_improvement

# ── Threat Intelligence ─────────────────────────────────────
# Optional: NVD API key for higher rate limits
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Git ─────────────────────────────────────────────────────
GIT_AUTHOR_NAME=TASO Bot
GIT_AUTHOR_EMAIL=taso@localhost

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_ROTATION=50 MB

# ── Application ─────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# ── Uncensored local LLM (Ollama) ────────────────────────────
# Fallback when primary model refuses a request
# Recommended: dolphin-mistral, wizard-vicuna-uncensored, nous-hermes
# Pull with: ollama pull dolphin-mistral
OLLAMA_UNCENSORED_MODEL=dolphin-mistral
UNCENSORED_REFUSAL_FALLBACK=true

# ── Swarm system ─────────────────────────────────────────────
# Enable parallel multi-agent task execution
SWARM_ENABLED=true
# Maximum subtasks running in parallel
SWARM_MAX_PARALLEL=5
# Per-subtask timeout in seconds
SWARM_TASK_TIMEOUT=120

# ── Model routing overrides (optional) ───────────────────────
# JSON mapping of model_name → {field: value} patches
# Example: MODEL_ROUTING_OVERRIDES={"gpt-4o": {"available": false}}
MODEL_ROUTING_OVERRIDES=
